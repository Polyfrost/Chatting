{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "Polyfrost"
    ],
    "contact": {
        "homepage": "https://polyfrost.org",
        "sources": "https://github.com/Polyfrost/Chatting",
        "issues": "https://github.com/Polyfrost/Chatting/issues"
    },
    "license": "LGPL-3.0-or-later",
    "icon": "assets/${mod_id}/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            {
                "value": "org.polyfrost.chatting.ChattingClient",
                "adapter": "kotlin"
            }
        ],
        "modmenu": [
            {
                "value": "org.polyfrost.chatting.integration.ChattingModMenuIntegration",
                "adapter": "kotlin"
            }
        ]
    },
    "mixins": [
        "mixins.${mod_id}.json"
    ],
    "accessWidener": "${aw}",
    "depends": {
        "minecraft": ">=${mc_version}",
        "fabricloader": ">=${loader_version}",
        "oneconfigv1": ">=1.0.0-beta.7",
        "fabric-language-kotlin": ">=1.13.8+kotlin.2.3.0"
    }
}
